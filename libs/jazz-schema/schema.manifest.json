{
	"tables": {
		"peers": {
			"columns": [
				{
					"name": "peer_did",
					"type": "text",
					"plaintext": true,
					"comment": "did:key of the remote peer — local allowlist; objects use nosync metadata so Groove never forwards this table over P2P"
				},
				{ "name": "label", "type": "text", "plaintext": true },
				{ "name": "added_at_ms", "type": "bigint", "plaintext": true },
				{
					"name": "status",
					"type": "text",
					"plaintext": true,
					"comment": "pending | active | revoked"
				}
			]
		},
		"keyshares": {
			"columns": [
				{ "name": "spark_id", "type": "uuid", "plaintext": true },
				{ "name": "dek_version", "type": "bigint", "plaintext": true },
				{ "name": "recipient_did", "type": "text", "plaintext": true },
				{ "name": "wrapped_dek", "type": "text", "plaintext": true }
			]
		},
		"sparks": {
			"columns": [
				{ "name": "spark_id", "type": "uuid", "plaintext": true },
				{ "name": "name", "type": "text", "plaintext": true },
				{
					"name": "issuer_pubkey_b64",
					"type": "text",
					"plaintext": true,
					"comment": "biscuit root Ed25519 public key (URL-safe base64, 32 bytes) — verifier anchor for genesis + third-party delegation blocks"
				},
				{ "name": "genesis_b64", "type": "text", "plaintext": true },
				{ "name": "current_dek_version", "type": "bigint", "plaintext": true },
				{ "name": "created_at_ms", "type": "bigint", "plaintext": true }
			]
		},
		"todos": {
			"columns": [
				{
					"name": "spark_id",
					"type": "uuid",
					"plaintext": true,
					"comment": "public linkage — ACC routing; ciphertext AAD binds rows to sparks"
				},
				{ "name": "title", "type": "text" },
				{
					"name": "done",
					"type": "text",
					"exposeTs": "boolean"
				},
				{ "name": "description", "type": "text", "nullable": true }
			]
		}
	}
}
