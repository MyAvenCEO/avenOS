{
	"tables": {
		"humans": {
			"columns": [
				{
					"name": "first_name",
					"type": "text",
					"plaintext": true,
					"comment": "singleton per vault — nosync Groove inserts (local-only identity graph)"
				},
				{ "name": "username_slug", "type": "text", "plaintext": true },
				{
					"name": "my_devices",
					"type": "uuid[]",
					"plaintext": true,
					"exposeTs": "string[]",
					"comment": "routing — ordered peer row object ids"
				},
				{
					"name": "created_at_ms",
					"type": "bigint",
					"plaintext": true,
					"comment": "local singleton metadata"
				}
			]
		},
		"peers": {
			"columns": [
				{
					"name": "owner",
					"type": "uuid",
					"plaintext": true,
					"nullable": true,
					"comment": "routing — caps-only sync. null = device-local trust-set row (not synced); admin-identity id = network roster row (syncs to admin-identity members)"
				},
				{
					"name": "peer_did",
					"type": "text",
					"plaintext": true,
					"comment": "did:key — peer/member identity"
				},
				{
					"name": "device_label",
					"type": "text",
					"plaintext": true,
					"comment": "e.g. MacBook M1 — self-published device label (admin-identity roster) / local label (trust-set)"
				},
				{
					"name": "account_name",
					"type": "text",
					"plaintext": true,
					"nullable": true,
					"comment": "self-published member display name in the admin-identity roster (null for plain trust-set rows). TODO(privacy): seal this + device_label so a blind replica can't read names — see board idea 0009."
				},
				{
					"name": "kind",
					"type": "text",
					"plaintext": true,
					"comment": "local | remote"
				},
				{
					"name": "added_at_ms",
					"type": "bigint",
					"plaintext": true,
					"comment": "local allowlist metadata"
				},
				{
					"name": "status",
					"type": "text",
					"plaintext": true,
					"comment": "pending | active | revoked"
				}
			]
		},
		"keyshares": {
			"columns": [
				{
					"name": "owner",
					"type": "uuid",
					"plaintext": true,
					"comment": "routing — keyshare lookup"
				},
				{
					"name": "dek_version",
					"type": "bigint",
					"plaintext": true,
					"comment": "routing — DEK version line"
				},
				{
					"name": "recipient_did",
					"type": "text",
					"plaintext": true,
					"comment": "routing — recipient DID"
				},
				{
					"name": "wrapper_did",
					"type": "text",
					"plaintext": true,
					"comment": "routing — granter DID for KEK derivation"
				},
				{
					"name": "wrapped_dek",
					"type": "text",
					"plaintext": true,
					"comment": "routing — wrapped DEK blob"
				}
			]
		},
		"identities": {
			"columns": [
				{
					"name": "owner",
					"type": "uuid",
					"plaintext": true,
					"comment": "routing — identity row identity"
				},
				{ "name": "name", "type": "text", "comment": "sealed at rest" },
				{
					"name": "issuer_pubkey_b64",
					"type": "text",
					"comment": "sealed — biscuit root Ed25519 public key (URL-safe base64)"
				},
				{ "name": "genesis_b64", "type": "text", "comment": "sealed — biscuit chain" },
				{
					"name": "current_dek_version",
					"type": "bigint",
					"plaintext": true,
					"comment": "routing — active DEK line for seal/hydrate"
				},
				{
					"name": "created_at_ms",
					"type": "bigint",
					"plaintext": true,
					"comment": "identity row metadata"
				}
			]
		},
		"todos": {
			"columns": [
				{
					"name": "owner",
					"type": "uuid",
					"plaintext": true,
					"comment": "routing — ACC + sync"
				},
				{ "name": "title", "type": "text" },
				{
					"name": "done",
					"type": "text",
					"exposeTs": "boolean"
				},
				{ "name": "description", "type": "text", "nullable": true }
			]
		},
		"messages": {
			"columns": [
				{
					"name": "owner",
					"type": "uuid",
					"plaintext": true,
					"comment": "routing — biscuit + P2P sync"
				},
				{
					"name": "created_at_ms",
					"type": "text",
					"exposeTs": "bigint",
					"comment": "sealed at rest"
				},
				{
					"name": "author_did",
					"type": "text",
					"comment": "sealed at rest"
				},
				{
					"name": "body",
					"type": "text",
					"comment": "sealed at rest"
				}
			]
		},
		"files": {
			"columns": [
				{
					"name": "owner",
					"type": "uuid",
					"plaintext": true,
					"comment": "routing — ACC + sync"
				},
				{ "name": "intent_id", "type": "text", "comment": "sealed at rest" },
				{ "name": "filename", "type": "text", "comment": "sealed at rest" },
				{
					"name": "mime_type",
					"type": "text",
					"comment": "sealed at rest"
				},
				{
					"name": "size_bytes",
					"type": "text",
					"exposeTs": "bigint",
					"comment": "sealed at rest"
				},
				{
					"name": "created_at_ms",
					"type": "text",
					"exposeTs": "bigint",
					"comment": "sealed at rest"
				},
				{
					"name": "content",
					"type": "bytea",
					"comment": "sealed at rest — IPC JSON uses base64"
				}
			]
		}
	}
}
