# ── Aven Self auth server (libs/aven-self — `bun run dev:aven-self`) ─────────────
# Loaded from repo-root `.env` by package scripts (`--env-file=../../.env`).
BETTER_AUTH_URL="http://localhost:3000"
# Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=""
AVEN_SELF_DB_PATH="./data/aven-self.db"
# Optional overrides:
# AVEN_SELF_DOMAIN="localhost:3000"
# AVEN_SELF_NETWORK_SEED="ceo.aven/testnet/abagana"
# AVEN_SELF_INVITE_TTL_SECONDS="86400"
# AVEN_SELF_INVITE_SCHEME="avenos"
