# ── Aven Self auth server (libs/aven-auth — `bun run dev:aven-auth`) ─────────────
# Loaded from repo-root `.env` by package scripts (`--env-file=../../.env`).
BETTER_AUTH_URL="http://localhost:3000"
# Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=""
AVEN_AUTH_DB_PATH="./data/aven-auth.db"
# Optional overrides:
# AVEN_AUTH_DOMAIN="localhost:3000"
# AVEN_AUTH_NETWORK_SEED="ceo.aven/testnet/abagana"
# AVEN_AUTH_INVITE_TTL_SECONDS="86400"
# AVEN_AUTH_INVITE_SCHEME="avenos"
