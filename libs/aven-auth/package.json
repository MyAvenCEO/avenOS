{
	"name": "@avenos/aven-auth",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "bun --env-file=../../.env ./scripts/dev-server.ts",
		"build": "bun --env-file=../../.env vite build",
		"preview": "bun --env-file=../../.env ./scripts/preview-server.ts",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"test": "bun --env-file=../../.env ./scripts/smoke-api.ts",
		"test:once": "bun --env-file=../../.env ./scripts/smoke-api.ts --once",
		"migrate": "bun --env-file=../../.env ./scripts/migrate.ts"
	},
	"dependencies": {
		"@noble/ed25519": "^2.2.3",
		"@noble/hashes": "^1.8.0",
		"better-auth": "^1.2.8",
		"better-sqlite3": "^11.9.1",
		"bs58": "^6.0.0"
	},
	"devDependencies": {
		"@sveltejs/adapter-node": "^5.2.12",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@types/better-sqlite3": "^7.6.13",
		"@types/node": "^22.13.9",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"typescript": "^6.0.2",
		"vite": "^8.0.7"
	}
}
