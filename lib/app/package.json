{
	"name": "@AvenOS/app",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"predev": "bun run --cwd ../../libs/jazz-schema build && bun ../../scripts/free-dev-server-port.ts",
		"dev": "bun --env-file=../../.env x --bun vite dev",
		"build:vibe-sandbox": "bun --cwd=../../libs/vibe-app-sandbox run build",
		"build": "bun run build:vibe-sandbox && bun --env-file=../../.env x --bun vite build",
		"preview": "bun --env-file=../../.env x --bun vite preview",
		"prepare": "bunx --bun svelte-kit sync || echo ''",
		"check": "bun run --cwd ../../libs/jazz-schema build && bunx --bun svelte-kit sync && bunx --bun svelte-check --tsconfig ./tsconfig.json && bun run docs:words",
		"docs:words": "bun run --cwd ../../libs/docs words:check",
		"tauri": "bunx --bun tauri",
		"tauri:dev": "bunx --bun tauri dev",
		"tauri:build:macos": "bunx --bun tauri build",
		"tauri:build:linux": "bunx --bun tauri build --bundles deb,appimage"
	},
	"devDependencies": {
		"@tauri-apps/cli": "^2",
		"@types/node": "^22.13.9",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/vite": "^4.2.4",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"tailwindcss": "^4.2.4",
		"typescript": "^6.0.2",
		"vite": "^8.0.7"
	},
	"dependencies": {
		"@avenos/jazz-schema": "workspace:*",
		"@avenos/docs": "workspace:*",
		"@avenos/vibe-app-sandbox": "workspace:*",
		"@avenos/vibe-apps": "workspace:*",
		"@modelcontextprotocol/ext-apps": "^1.0.0",
		"@modelcontextprotocol/sdk": "^1.29.0",
		"dompurify": "^3",
		"github-slugger": "^2",
		"marked": "^15",
		"@tauri-apps/api": "^2",
		"@xterm/addon-fit": "^0.11.0",
		"@xterm/addon-web-links": "^0.12.0",
		"@xterm/xterm": "^6.0.0",
		"xterm-pty": "^0.12.0"
	}
}
