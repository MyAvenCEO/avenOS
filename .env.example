# Injected / managed by `jazzSvelteKit` in dev when using a local Jazz server.
# For Jazz Cloud or a remote dev server, set these explicitly (see https://dashboard.jazz.tools).
PUBLIC_JAZZ_APP_ID="your-jazz-app-id"
PUBLIC_JAZZ_SERVER_URL="https://your-jazz-server-url"

# When set to `1`, **vite dev** clears `PUBLIC_JAZZ_SERVER_URL` so the Jazz plugin uses **embedded local sync**
# instead of Jazz Cloud — fixes dev when the cloud app has **unreachable schema branches**,
# **`CatalogueWriteDenied`**, or migration drift (see server stderr).
# Omit for production / CI. Use `0` or unset when you intentionally target Jazz Cloud with a clean app.
# In `projects/aven-ceo` you can run `bun run dev:local` to force this for one session without editing `.env`.
# JAZZ_DEV_USE_LOCAL=1
#
# Jazz Cloud recovery (stderr mentions `unreachable_schema_hashes` or `CatalogueWriteDenied`):
# - Prefer a **new app** in https://dashboard.jazz.tools and fresh `PUBLIC_JAZZ_APP_ID` + secrets, or
# - Generate migrations: `bunx jazz-tools@alpha migrations create --fromHash <old> --toHash <current>`
#   for each unreachable hash vs your current schema hash (also logged), then push schema again.

# Required when PUBLIC_JAZZ_SERVER_URL points at a remote server (schema + permissions push from the dev plugin).
# Must match the Admin secret for this app in https://dashboard.jazz.tools — wrong/missing values cause
# `Schema publish failed` (often with an HTML body) and Vite will exit during `configureServer`.
JAZZ_ADMIN_SECRET="your-jazz-admin-secret"

# Issued by the Jazz dev server for local-first JWKS; keep in sync with your server / dashboard.
# Jazz expects 32 bytes: use the dashboard/dev value (base64url), 64 hex chars, any UTF-8 string exactly
# 32 bytes long, or a shorter arbitrary string (hashed to 32 bytes by the app — OK for local dev only).
BACKEND_SECRET="your-backend-secret"

# Jaensen local / box setup (optional alternative to Tinfoil):
# JAENSEN_PORT="7341"
# JAENSEN_DB_PATH=".jaensen/state.db"
# JAENSEN_WORKSPACE_ROOT="."
# JAENSEN_SKILLS_ROOT="skills"
# JAENSEN_TICK_IDLE_MS="100"
# JAENSEN_LEASE_MS="60000"
# JAENSEN_LOG_LEVEL="debug"
# JAENSEN_OPENAI_API_KEY="local"
# JAENSEN_OPENAI_BASE_URL="http://box:8000/v1"
# JAENSEN_OPENAI_MODEL="minimax-m2.7-nvfp4"

# Jaensen Tinfoil setup (server-only):
JAENSEN_TINFOIL_MODEL="glm-5-1"
JAENSEN_TINFOIL_BASE_URL="https://api.tinfoil.sh/v1"
JAENSEN_TINFOIL_API_KEY="your-tinfoil-api-key"

# Legacy Tinfoil key used by other Aven endpoints if needed.
TINFOIL_API_KEY="your-tinfoil-api-key"

# Optional. Vault-owner note basename only — must match OWNER_*.md (e.g. OWNER_jamie.md). File lives under Humans/ in the vault.
AVEN_VAULT_OWNER_HUMANS_FILE="OWNER_your-name"


GOOGLE_API_KEY="your-google-api-key"

# Vibe sandbox (`bun dev:app`): listen port — `VIBE_SANDBOX_PORT` preferred, else `PORT`, default 8081 (dev retries 8081–8086 if both unset).
# lib/app defaults to http://localhost:8081/sandbox.html — when you change the port, set this so the iframe matches:
# VIBE_SANDBOX_PORT=8082
# PUBLIC_VIBE_SANDBOX_URL="http://localhost:8082/sandbox.html"