# Optional waitlist webhook (Slack-compatible JSON). When unset, submissions log to the server console.
# WAITLIST_WEBHOOK_URL="https://hooks.slack.com/services/..."

# Legacy Tinfoil key used by other Aven endpoints if needed.
TINFOIL_API_KEY="your-tinfoil-api-key"

# Optional. Vault-owner note basename only — must match OWNER_*.md (e.g. OWNER_jamie.md). File lives under Humans/ in the vault.
AVEN_VAULT_OWNER_HUMANS_FILE="OWNER_your-name"

GOOGLE_API_KEY="your-google-api-key"

# Vibe sandbox (`bun dev:app`): listen port — `VIBE_SANDBOX_PORT` preferred, else `PORT`, default 8081 (dev retries 8081–8086 if both unset).
# app defaults to http://localhost:8081/sandbox.html — when you change the port, set this so the iframe matches:
# VIBE_SANDBOX_PORT=8082
# PUBLIC_VIBE_SANDBOX_URL="http://localhost:8082/sandbox.html"

# ── Aven Self auth server (libs/aven-self — `bun run dev:aven-self`) ─────────────
# BETTER_AUTH_URL="http://localhost:3000"
# BETTER_AUTH_SECRET=""  # openssl rand -base64 32
# AVEN_SELF_DB_PATH="./data/aven-self.db"
