# Optional waitlist webhook (Slack-compatible JSON). When unset, submissions log to the server console.
# WAITLIST_WEBHOOK_URL="https://hooks.slack.com/services/..."

# Legacy Tinfoil key used by other Aven endpoints if needed.
TINFOIL_API_KEY="your-tinfoil-api-key"

# Optional. Vault-owner note basename only — must match OWNER_*.md (e.g. OWNER_jamie.md). File lives under Humans/ in the vault.
AVEN_VAULT_OWNER_HUMANS_FILE="OWNER_your-name"

GOOGLE_API_KEY="your-google-api-key"

# Vibe sandbox (`bun dev:app`): listen port — `VIBE_SANDBOX_PORT` preferred, else `PORT`, default 8081 (dev retries 8081–8086 if both unset).
# app defaults to http://localhost:8081/sandbox.html — when you change the port, set this so the iframe matches:
# VIBE_SANDBOX_PORT=8082
# PUBLIC_VIBE_SANDBOX_URL="http://localhost:8082/sandbox.html"

# ── AvenOS P2P mode (discovery vs data plane) ───────────────────────────────────────────────────
# AVEN_RELAY defaults ON (central discovery: HyperDHT bootstrap + optional local relay subprocess).
# Set AVEN_RELAY=false for public Holepunch HyperDHT instead.
# AVEN_RELAY="false"
# AVENOS_SKIP_P2P_SIGNAL="1"
#
# REQUIRED when AVEN_RELAY is on for packaged/production env (no bake-in — set in .env / launchd / CI).
# Dev wrappers (`dev:app:*`, `dev:app2x`) default unset → 127.0.0.1 (embedded local signal); set explicitly anyway for clarity:
AVEN_RELAY_URL="127.0.0.1"
#
# Hosted Fly bootstrap (deploy: `bun run deploy:relay-fly`; DNS A relay → Fly IPv4; see docs/network/developers/05-p2p-signal.md):
# AVEN_RELAY_URL="relay.aven.ceo"
#
# Central blind-relay identity (repo-root `.env`, same pattern as GENESIS_NETWORK_ID — never commit the seed):
# Generate seed once:  openssl rand -hex 32
# Derive public key:   bun run derive:relay-pubkey
# AVENOS_RELAY_SEED_HEX="<64 hex chars>"
# AVENOS_RELAY_PUBLIC_KEY_HEX="<64 hex chars>"
#
# Embedded local stacks (scripts/p2p-signal.ts) use 127.0.0.1 / localhost / ::1 → spawns Rust DHT subprocess only.
# Any other hostname → no subprocess; Tauri merges AVENOS_DHT_BOOTSTRAP=127.0.0.1@{host}:{AVENOS_P2P_SIGNAL_PORT}.
#
# Central mode merges (from scripts/p2p-signal.ts or tauri-plugin-peer — do not duplicate unless overriding):
# AVENOS_DHT_ISOLATED="1"
# AVENOS_DHT_BOOTSTRAP="127.0.0.1@127.0.0.1:49737"
#
# Public mode merges: AVENOS_DHT_PUBLIC="1"

# ── AvenOS desktop P2P (Hyperswarm / peeroxide) — Tauri process env, not Vite ───────────────────
# Central mode packaging: AVEN_RELAY_URL must reach the Hyperswarm host; if AVENOS_DHT_BOOTSTRAP is omitted,
# tauri-plugin-peer derives 127.0.0.1@{AVEN_RELAY_URL}:{AVENOS_P2P_SIGNAL_PORT} (defaults to 49737).
# Comma-separated HyperDHT bootstrap strings (`ip@host:port`; same form as Holepunch defaults).
# AVENOS_DHT_BOOTSTRAP="192.168.1.50@relay.lan:49737"

# Connection caps (optional, positive integers).
# AVENOS_HYPERSWARM_MAX_PARALLEL="4"
# AVENOS_HYPERSWARM_MAX_PEERS="128"
