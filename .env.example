# Injected / managed by `jazzSvelteKit` in dev when using a local Jazz server.
# For Jazz Cloud or a remote dev server, set these explicitly (see https://dashboard.jazz.tools).
PUBLIC_JAZZ_APP_ID=
PUBLIC_JAZZ_SERVER_URL=

# Required when PUBLIC_JAZZ_SERVER_URL points at a remote server (schema + permissions push from the dev plugin).
JAZZ_ADMIN_SECRET=

# Issued by the Jazz dev server for local-first JWKS; keep in sync with your server / dashboard.
BACKEND_SECRET=

# Tinfoil (server-only). Required for POST /api/aven/intent and POST /api/aven/chat — never expose as PUBLIC_*.
TINFOIL_API_KEY=

# Optional. Vault-owner note basename only — must match OWNER_*.md (e.g. OWNER_jamie.md). File lives under Humans/ in the vault.
AVEN_VAULT_OWNER_HUMANS_FILE=
