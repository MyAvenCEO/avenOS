# WebSocket peer for Jazz Cloud (include ?key=… from https://dashboard.jazz.tools when required)
PUBLIC_JAZZ_SYNC_PEER=wss://v2.sync.jazz.tools

# Optional: used by jazz-tools dev tooling when pushing permissions to a remote server (not shipped in the jazz-tools@0.20 published package; keep for when you upgrade / use CLI deploy)
# JAZZ_ADMIN_SECRET=
