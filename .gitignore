node_modules

# Local second brain vault + upstream mirrors (never commit)
/.data/
/libs/aven-website/.data/
/.repos/

# Output
.output
.vercel
.netlify
.wrangler
/.svelte-kit
/ARCHIVE/*/.svelte-kit
/app/.svelte-kit
/libs/aven-website/.svelte-kit
/build
