# Python
__pycache__/
*.py[cod]
*.pyo

# Vite
vite.config.js.timestamp-*
vite.config.ts.timestamp-*

# Vibe app sandbox + mini-app build outputs (rebuilt by `bun run build` per package).
/libs/aven-vibe-sandbox/sandbox/dist/
/libs/aven-vibes/*/dist/

# Upstream jazz2 mirror (local refresh only — never commit)
/tools/jazz2-upstream/
# Ephemeral overlay stash for scripts/revendor-aven-db.sh
/.avenos-revendor-backup/
target/
**/target/

# App Store / local packaging outputs (never commit)
/dist/
**/*.pkg

# Repo-local P2p signal relay keys (relay-hyperdht.seed, bootstrap-hyperdht.seed)
/.avenOS/
**/.avenOS/

# Provisioned onnxruntime dylib for the on-device LLM (`ort` load-dynamic).
# Fetched by scripts/fetch-onnxruntime.ts (matches the version ort targets); a
# ~35MB binary — not committed, re-downloaded on demand / at packaging.
/app/src-tauri/onnxruntime/

# video-edit skill: generated / large media — re-render (render.sh) or re-fetch
# (fetch_stock.py / tts_synth) locally; never commit the binaries.
/app/static/skills/editing/*.mp4
/app/static/skills/editing/*.wav
.claude/skills/video-edit/examples/**/assets/
# Ephemeral Claude Code dev artifacts
/.claude/scheduled_tasks.lock

# Local dev preview config (machine-specific absolute paths)
/.claude/launch.json
