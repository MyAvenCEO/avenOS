{
	"name": "avenos",
	"private": true,
	"type": "module",
	"workspaces": [
		"projects/*",
		"libs/*",
		"app"
	],
	"scripts": {
		"dev": "bun --env-file=.env run dev:aven-ceo",
		"dev:local": "JAENSEN_OPENAI_API_KEY=local JAENSEN_OPENAI_BASE_URL=http://box:8000/v1 JAENSEN_OPENAI_MODEL=minimax-m2.7-nvfp4 bun --env-file=.env run dev:aven-ceo",
		"dev:tinfoil": "bun --env-file=.env run dev:aven-ceo",
		"dev:aven-ceo": "bun --env-file=.env --filter @avenos/aven-ceo dev",
		"dev:stack": "bun ./projects/dev-stack/run-dev.ts",
		"dev:app": "bun --env-file=.env run --cwd app dev",
		"dev:app:all": "bun --env-file=.env ./scripts/dev-app-all.ts",
		"dev:app:mac": "bun --env-file=.env ./scripts/dev-app-macos.ts",
		"dev:app:ios": "bun --env-file=.env ./scripts/dev-app-ios.ts",
		"dev:app:linux": "bun --env-file=.env ./scripts/dev-app-linux.ts",
		"clean:app:rust": "bun ./scripts/clean-app-tauri-target.ts",
		"dev:p2p-signal": "bun ./scripts/p2p-signal.ts --foreground",
		"dev:app2x:mac": "bun --env-file=.env ./scripts/dev-two-instances.ts",
		"dev:app2x:linux": "bun --env-file=.env ./scripts/dev-two-instances.ts",
		"build:app:linux": "bun run --cwd app tauri:build:linux",
		"release:app:all": "bun ./scripts/release-app.ts all",
		"release:app:mac": "bun ./scripts/release-app.ts mac",
		"release:app:ios": "bun ./scripts/release-app.ts ios",
		"fetch:webcm": "bun run ./scripts/fetch-webcm.ts",
		"dev:all": "concurrently -k -c auto -n backend,svelte-app \"bun run dev:stack\" \"bun run --cwd app dev\"",
		"dev:jaensen-server": "bun --env-file=.env --filter @jaensen/web-api dev",
		"dev:ocr-example": "bun --env-file=.env --filter @avenos/ocr-example dev",
		"dev:jaensen-bot": "bun --env-file=.env --filter @avenos/jaensen-bot dev",
		"check:jaensen": "bun --env-file=.env --filter '@jaensen/*' typecheck",
		"test:mail": "bun --env-file=.env --filter @avenos/mail test",
		"test:jaensen": "bun --env-file=.env --filter '@jaensen/*' test",
		"build": "bun --env-file=.env --filter @avenos/aven-ceo build",
		"preview": "bun --env-file=.env --filter @avenos/aven-ceo preview",
		"check": "bun --env-file=.env --filter @avenos/aven-ceo check",
		"prepare": "bun --env-file=.env --filter @avenos/aven-ceo prepare",
		"lint": "bunx biome check .",
		"lint:fix": "bunx biome check --write .",
		"format": "bunx biome format --write .",
		"deploy:relay-fly": "bun ./scripts/deploy-relay-fly.ts",
		"derive:relay-pubkey": "bun ./scripts/derive-relay-pubkey.ts",
		"migrate:relay-env": "bun ./scripts/migrate-relay-seed-to-env.ts"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.14",
		"concurrently": "^9.2.1"
	}
}
