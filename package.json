{
	"name": "avenos",
	"private": true,
	"type": "module",
	"workspaces": [
		"projects/*",
		"../MaiaOS/libs/*"
	],
	"scripts": {
		"dev": "bun run dev:aven-ceo",
		"dev:aven-ceo": "bun --filter @avenos/aven-ceo dev",
		"dev:ocr-example": "bun --filter @avenos/ocr-example dev",
		"dev:jaensen-bot": "bun --filter @avenos/jaensen-bot dev",
		"test:mail": "bun --filter @avenos/mail test",
		"test:self": "bun --filter @avenos/self test",
		"build": "bun --filter @avenos/aven-ceo build",
		"preview": "bun --filter @avenos/aven-ceo preview",
		"check": "bun --filter @avenos/aven-ceo check",
		"prepare": "bun --filter @avenos/aven-ceo prepare",
		"lint": "bunx biome check .",
		"lint:fix": "bunx biome check --write .",
		"format": "bunx biome format --write ."
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.14"
	}
}
