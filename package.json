{
	"name": "avenos",
	"private": true,
	"type": "module",
	"workspaces": [
		"projects/*"
	],
	"scripts": {
		"dev": "bun --env-file=.env run dev:aven-ceo",
		"dev:local": "JAENSEN_OPENAI_API_KEY=local JAENSEN_OPENAI_BASE_URL=http://box:8000/v1 JAENSEN_OPENAI_MODEL=minimax-m2.7-nvfp4 bun --env-file=.env run dev:aven-ceo",
		"dev:tinfoil": "bun --env-file=.env run dev:aven-ceo",
		"dev:aven-ceo": "bun --env-file=.env --filter @avenos/aven-ceo dev",
		"dev:jaensen-server": "bun --env-file=.env --filter @jaensen/web-api dev",
		"dev:ocr-example": "bun --env-file=.env --filter @avenos/ocr-example dev",
		"dev:jaensen-bot": "bun --env-file=.env --filter @avenos/jaensen-bot dev",
		"check:jaensen": "bun --env-file=.env --filter '@jaensen/*' typecheck",
		"test:mail": "bun --env-file=.env --filter @avenos/mail test",
		"test:jaensen": "bun --env-file=.env --filter '@jaensen/*' test",
		"build": "bun --env-file=.env --filter @avenos/aven-ceo build",
		"preview": "bun --env-file=.env --filter @avenos/aven-ceo preview",
		"check": "bun --env-file=.env --filter @avenos/aven-ceo check",
		"prepare": "bun --env-file=.env --filter @avenos/aven-ceo prepare",
		"lint": "bunx biome check .",
		"lint:fix": "bunx biome check --write .",
		"format": "bunx biome format --write ."
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.14"
	}
}
