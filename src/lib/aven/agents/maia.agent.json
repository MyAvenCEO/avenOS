{
	"$schema": "../schemas/agent.schema.json",
	"id": "aven.maia.v1",
	"name": "Maia",
	"version": "1.0.0",
	"llm": {
		"provider": "tinfoil",
		"temperature": 0.3,
		"maxToolRounds": 12,
		"defaultModel": "glm-5-1",
		"toolChoice": "auto",
		"fallbackConfigFiles": ["tinfoil-chat.config.json"]
	},
	"sources": {
		"systemPrompt": {
			"kind": "markdown_frontmatter_raw",
			"path": ".data/agents/maia/RULES.md",
			"seedPath": "seed/agents/maia/RULES.md"
		},
		"tools": {
			"openAiFunctionSchemas": ".data/agents/maia/tools/memory.openai.json"
		},
		"transcript": {
			"conversationJsonRelative": ".data/agents/maia/messages/conversation.json",
			"messageMarkdownGlob": ".data/agents/maia/messages/m*.md"
		},
		"identityMarkdown": ".data/agents/maia/SOUL.md"
	},
	"systemBundle": {
		"delimiterMarkdown": "---",
		"snapshotHeadingMarkdownTemplate": "## Vault snapshot ({iso})"
	},
	"contextPreview": {
		"sectionHeadings": {
			"soul": "@.data/agents/maia/SOUL.md",
			"owner": "Vault owner (`Humans/OWNER_*.md` — Identity & Preferences)",
			"rules": "@.data/agents/maia/RULES.md",
			"vaultSnapshot": "@.data/knowledge (live index)",
			"vaultGraph": "@.data/state/vault-graph.json (derived wikilink summary)",
			"tools": "@.data/agents/maia/tools/memory.openai.json",
			"transcript": "@.data/agents/maia/messages"
		},
		"toolBadgeTailwindClasses": {
			"memory_list_notes": "border-violet-400/35 bg-violet-500/[0.14] text-violet-950",
			"memory_read_file": "border-sky-400/35 bg-sky-500/[0.14] text-sky-950",
			"memory_edit": "border-amber-400/40 bg-amber-500/[0.16] text-amber-950",
			"memory_write_file": "border-emerald-400/35 bg-emerald-500/[0.14] text-emerald-950",
			"memory_search": "border-fuchsia-400/35 bg-fuchsia-500/[0.13] text-fuchsia-950"
		}
	}
}
