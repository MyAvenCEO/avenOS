{
  "name": "typed-actors",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run --pool=threads --poolOptions.threads.singleThread=true",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test:types": "bun run build && bunx tsd --files tests/type-safety.test-d.ts"
  },
  "devDependencies": {
    "@types/node": "^24.10.0",
    "tsd": "^0.31.2",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
