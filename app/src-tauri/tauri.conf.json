{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "avenOS",
	"mainBinaryName": "aven-os-app",
	"version": "26.6.1-next.14",
	"identifier": "ceo.aven.os",
	"build": {
		"beforeDevCommand": "bun run dev",
		"devUrl": "http://127.0.0.1:1420",
		"beforeBuildCommand": "bun run build",
		"frontendDist": "../build"
	},
	"app": {
		"macOSPrivateApi": true,
		"windows": [
			{
				"label": "main",
				"title": "avenOS",
				"width": 1280,
				"height": 800,
				"minWidth": 960,
				"minHeight": 600,
				"dragDropEnabled": false
			}
		],
		"security": {
			"csp": {
				"default-src": "'self'",
				"script-src": "'self' 'unsafe-inline' 'wasm-unsafe-eval'",
				"style-src": "'self' 'unsafe-inline'",
				"img-src": "'self' data: blob:",
				"font-src": "'self' data:",
				"media-src": "'self' blob:",
				"frame-src": "'self' blob: http://localhost:*",
				"object-src": "'self' blob:",
				"worker-src": "'self' blob:",
				"connect-src": "'self' ipc: http://ipc.localhost blob: https://cdn.jsdelivr.net",
				"base-uri": "'self'",
				"form-action": "'self'"
			},
			"devCsp": {
				"default-src": "'self'",
				"script-src": "'self' 'unsafe-inline' 'wasm-unsafe-eval'",
				"style-src": "'self' 'unsafe-inline'",
				"img-src": "'self' data: blob:",
				"font-src": "'self' data:",
				"media-src": "'self' blob:",
				"frame-src": "'self' blob: http://localhost:* http://127.0.0.1:*",
				"object-src": "'self' blob:",
				"worker-src": "'self' blob:",
				"connect-src": "'self' ipc: http://ipc.localhost blob: https://cdn.jsdelivr.net ws://localhost:* ws://127.0.0.1:* http://localhost:* http://127.0.0.1:*",
				"base-uri": "'self'",
				"form-action": "'self'"
			},
			"dangerousDisableAssetCspModification": ["script-src", "style-src"],
			"headers": {
				"Cross-Origin-Opener-Policy": "same-origin",
				"Cross-Origin-Embedder-Policy": "require-corp",
				"Cross-Origin-Resource-Policy": "same-origin"
			}
		}
	},
	"bundle": {
		"active": true,
		"category": "Productivity",
		"targets": ["app", "dmg"],
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		],
		"resources": {
			"../../libs/aven-schema/schema.manifest.json": "aven-schema/schema.manifest.json",
			"../../libs/aven-schema/migrations/registry.json": "aven-schema/migrations/registry.json",
			"../../libs/aven-schema/migrations/snapshots/before-files.manifest.json": "aven-schema/migrations/snapshots/before-files.manifest.json",
			"onnxruntime/libonnxruntime.dylib": "onnxruntime/libonnxruntime.dylib",
			"resources/moss-tts-nano/tokenizer.json": "resources/moss-tts-nano/tokenizer.json"
		},
		"macOS": {
			"minimumSystemVersion": "12.0"
		}
	}
}
