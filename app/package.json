{
	"name": "@AvenOS/app",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"predev": "bun ../scripts/free-dev-server-port.ts",
		"dev": "AVENOS_DEV_INSTANCE=A bun --env-file=../.env x --bun vite dev",
		"build": "bun --env-file=../.env x vite build",
		"preview": "bun --env-file=../.env x --bun vite preview",
		"prepare": "[ -e node_modules ] || ln -sf ../node_modules node_modules; bun --bun x svelte-kit sync || echo ''",
		"check": "bun --bun x svelte-kit sync && bun --bun x svelte-check --tsconfig ./tsconfig.json && bun run docs:words",
		"test": "bun test tests",
		"docs:words": "bun run --cwd ../docs words:check",
		"tauri": "bun --bun x tauri",
		"tauri:dev": "bun --bun x tauri dev",
		"tauri:ios:dev:sim": "bun --bun x tauri ios dev",
		"tauri:build:macos": "bun --bun x tauri build",
		"tauri:build:linux": "bun --bun x tauri build --bundles deb,appimage",
		"tauri:ios:build:asc": "bun ../scripts/tauri-ios-asc.ts"
	},
	"devDependencies": {
		"@tauri-apps/cli": "^2",
		"@types/node": "^22.13.9",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/vite": "^4.2.4",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"tailwindcss": "^4.2.4",
		"typescript": "^6.0.2",
		"vite": "^8.0.7"
	},
	"dependencies": {
		"@avenos/aven-ui": "workspace:*",
		"@avenos/aven-city": "workspace:*",
		"@avenos/aven-board": "workspace:*",
		"@avenos/docs": "workspace:*",
		"@tauri-apps/api": "^2",
		"@tauri-apps/plugin-clipboard-manager": "^2.3.2",
		"@xterm/addon-fit": "^0.11.0",
		"@xterm/addon-web-links": "^0.12.0",
		"@xterm/xterm": "^6.0.0",
		"dompurify": "^3",
		"github-slugger": "^2",
		"marked": "^15",
		"pdfjs-dist": "^5.7.284",
		"xterm-pty": "^0.12.0"
	}
}
