[package]
name = "jazz-tools"
version = "2.0.0-alpha.0"
edition = "2024"
description = "Jazz local-first relational database core, runtime, client, and CLI."
license = "MIT OR Apache-2.0"
repository = "https://github.com/garden-co/jazz2"

[lib]
name = "groove"
path = "src/lib.rs"

[features]
default = []
surrealkv = ["dep:surrealkv", "dep:tokio"]
runtime-tokio = ["dep:tokio"]
transport = []
transport-http = ["transport", "dep:reqwest", "dep:base64", "dep:bytes"]
peer-transport = ["dep:bincode", "dep:async-trait"]
# AvenOS Tauri: SurrealKV + P2P only (no HTTP Jazz server / reqwest).
client-p2p = [
  "runtime-tokio",
  "surrealkv",
  "peer-transport",
  "dep:thiserror",
  "dep:tokio",
]
# Full upstream client: client-p2p + HTTP sync/streaming to a Jazz server.
client = ["client-p2p", "transport-http"]

# CLI binary + HTTP server (upstream dev only; not shipped in AvenOS apps).
cli = [
  "runtime-tokio",
  "transport",
  "surrealkv",
  "transport-http",
  "dep:tokio",
  "dep:axum",
  "dep:clap",
  "dep:tracing-subscriber",
  "dep:tower-http",
  "dep:async-stream",
  "dep:jsonwebtoken",
  "dep:base64",
  "dep:bytes",
]

[[bin]]
name = "jazz-tools"
path = "src/main.rs"
required-features = ["cli"]

[dependencies]
futures = "0.3"
tracing = "0.1"
uuid = { version = "1", features = ["v4", "v5", "v7", "serde"] }
blake3 = "1"
hex = "0.4"
rand = "0.8"
serde = { version = "1", features = ["derive"] }
serde_json = "1"
internment = "0.8"
smallvec = { version = "1.11", features = ["serde"] }
smolset = "1.3"
web-time = "1.1"
small-map = "0.1"
bitvec = "1.0"
ahash = "0.8"

tokio = { version = "1", features = ["full"], optional = true }
bincode = { version = "2.0", features = ["serde"], optional = true }
async-trait = { version = "0.1", optional = true }
surrealkv = { version = "0.19", optional = true }
thiserror = { version = "1", optional = true }

reqwest = { version = "0.12", features = ["json", "stream"], optional = true }
bytes = { version = "1", optional = true }
base64 = { version = "0.22", optional = true }

axum = { version = "0.7", optional = true }
clap = { version = "4", features = ["derive", "env"], optional = true }
tracing-subscriber = { version = "0.3", features = ["env-filter"], optional = true }
tower-http = { version = "0.5", features = ["cors", "trace"], optional = true }
async-stream = { version = "0.3", optional = true }
jsonwebtoken = { version = "9", optional = true }

[target.'cfg(target_arch = "wasm32")'.dependencies]
opfs-btree = { path = "../jazz2-upstream/crates/opfs-btree", version = "0.1.0" }

[dev-dependencies]
reqwest = { version = "0.12", features = ["json", "stream"] }
bytes = "1"
tempfile = "3"
jsonwebtoken = "9"
serde_json = "1"
serde = { version = "1", features = ["derive"] }
futures = "0.3"
tokio = { version = "1", features = ["test-util", "full"] }

[[test]]
name = "auth_test"
path = "tests/auth_test.rs"
required-features = ["cli"]

[[test]]
name = "integration"
path = "tests/integration.rs"
required-features = ["cli"]

[[test]]
name = "peer_transport_codec"
path = "tests/peer_transport_codec.rs"
required-features = ["client-p2p"]
